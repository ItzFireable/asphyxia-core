extends _layout.pug

block content
  .card.has-table
    header.card-header
      p.card-header-title
        span.icon
          i.mdi.mdi-server-network
        span Manage Cabinets
      .card-header-icon
        button.button.is-primary.is-small(onclick="document.getElementById('modal-add').classList.add('is-active')") Add Cabinet
    .card-content
      .table-wrapper.has-mobile-cards
        if cabinets && cabinets.length > 0
          table.table.is-fullwidth.is-striped.is-hoverable
            thead
              tr
                th PCBID
                th Name
                th MAC Addr
                th Linked Arcade
                th Actions
            tbody
              each cab in cabinets
                tr
                  td(data-label="PCBID")
                    code #{cab.pcbid}
                  td(data-label="Name") #{cab.name}
                  td(data-label="MAC Addr") #{cab.mac || 'N/A'}
                  td(data-label="Linked Arcade") 
                    if cab.arcade_id
                      if arcades
                        - var a = arcades.find(x => x.id === cab.arcade_id)
                        if a
                          span.tag.is-info #{a.name}
                        else
                          span.tag.is-danger Invalid Arcade
                    else
                      span.tag.is-warning Unlinked
                  td.is-actions-cell
                    .buttons.is-right
                      button.button.is-small.is-info(onclick=`editCabinet('${cab.pcbid}', '${cab.name.replace(/'/g, "\\'")}', '${cab.mac || ''}', '${cab.arcade_id || ''}')`)
                        span.icon
                          i.mdi.mdi-pencil
                      form(action="/admin/cabinets/delete" method="post" onsubmit="return confirm('Are you sure you want to delete this cabinet?');" style="display:inline;")
                        input(type="hidden" name="pcbid" value=cab.pcbid)
                        button.button.is-small.is-danger(type="submit")
                          span.icon
                            i.mdi.mdi-trash-can
        else
          section.section
            .content.has-text-grey.has-text-centered
              p
                span.icon.is-large
                  i.mdi.mdi-emoticon-sad.mdi-48px
              p No Cabinets registered yet.

block modal
  #modal-add.modal
    .modal-background(onclick="document.getElementById('modal-add').classList.remove('is-active')")
    .modal-card
      header.modal-card-head
        p.modal-card-title Add Cabinet
        button.delete(aria-label="close" onclick="document.getElementById('modal-add').classList.remove('is-active')")
      section.modal-card-body
        form(action="/admin/cabinets/create" method="post")
          .field
            label.label PCBID
            .control.has-icons-left
              input.input(type="text" name="pcbid" required placeholder="00000000000000000000")
              span.icon.is-small.is-left
                i.mdi.mdi-identifier
          .field
            label.label Name
            .control
              input.input(type="text" name="name" placeholder="Friendly Name")
          .field
            label.label MAC Address (Optional)
            .control
              input.input(type="text" name="mac" placeholder="00:11:22:33:44")
          hr
          .field.is-grouped.is-grouped-right
            .control
              button.button.is-primary(type="submit") Register

  #modal-edit.modal
    .modal-background(onclick="document.getElementById('modal-edit').classList.remove('is-active')")
    .modal-card
      header.modal-card-head
        p.modal-card-title Edit Cabinet
        button.delete(aria-label="close" onclick="document.getElementById('modal-edit').classList.remove('is-active')")
      section.modal-card-body
        form(action="/admin/cabinets/update" method="post")
          input#edit-pcbid(type="hidden" name="pcbid" value="")
          .field
            label.label PCBID
            .control
              input.input#edit-pcbid-disp(type="text" disabled)
          .field
            label.label Name
            .control
              input.input#edit-name(type="text" name="name")
          .field
            label.label MAC Address
            .control
              input.input#edit-mac(type="text" name="mac")
          .field
            label.label Link to Arcade
            .control
              .select.is-fullwidth
                select#edit-arcade(name="arcade_id")
                  option(value="unlinked") -- Unlinked --
                  if arcades
                    each a in arcades
                      option(value=a.id) #{a.name} (#{a.region})
          hr
          .field.is-grouped.is-grouped-right
            .control
              button.button.is-info(type="submit") Update

block scripts
  script.
    function editCabinet(pcbid, name, mac, arcade_id) {
      document.getElementById('edit-pcbid').value = pcbid;
      document.getElementById('edit-pcbid-disp').value = pcbid;
      document.getElementById('edit-name').value = name;
      document.getElementById('edit-mac').value = mac;
      document.getElementById('edit-arcade').value = arcade_id || 'unlinked';
      document.getElementById('modal-edit').classList.add('is-active');
    }
